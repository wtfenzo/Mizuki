{
	"name": "mizuki",
	"version": "1.0.0",
	"description": "A discord bot",
	"main": "dist/index.js",
	"scripts": {
		"start": "node dist/index.js",
		"build": "rimraf ./dist && npm run build:prisma && npm run build:ts",
		"build:ts": "tsc && tsc-alias",
		"build:prisma": "prisma generate",
		"dev": "nodemon --exec tsx src/index.ts",
		"lint:format": "biome check --write"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wtfenzo/Mizuki.git"
	},
	"keywords": [],
	"author": "wtfenzo ( iTachi )",
	"license": "ISC",
	"type": "module",
	"bugs": {
		"url": "https://github.com/wtfenzo/Mizuki/issues"
	},
	"homepage": "https://github.com/wtfenzo/Mizuki#readme",
	"dependencies": {
		"@prisma/adapter-pg": "^7.0.0",
		"@prisma/client": "^7.0.0",
		"discord.js": "^14.25.0",
		"dotenv": "^17.2.3",
		"pg": "^8.16.3",
		"redis": "^5.9.0",
		"uuid": "^13.0.0",
		"winston": "^3.18.3",
		"winston-daily-rotate-file": "^5.0.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.4",
		"@types/node": "^24.10.0",
		"@types/pg": "^8.15.6",
		"nodemon": "^3.1.10",
		"pm2": "^6.0.13",
		"prisma": "^7.0.0",
		"rimraf": "^6.1.0",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	}
}
